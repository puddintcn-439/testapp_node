    "pilot": "ts-node src/scripts/pilot.ts"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "@octokit/rest": "^19.0.9",
    "@octokit/auth-app": "^3.0.0",
    "ioredis": "^5.3.2",
    "bullmq": "^1.81.0"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.0",
    "@types/js-yaml": "^4.0.5",
    "jest": "^29.6.1",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.2",
    "jest-environment-node": "^29.6.1",
    "ts-node": "^10.9.1"
